# =============================================================================
# Loan Application Agent - Frontend Environment Configuration
# =============================================================================
# Copy this file to frontend/.env.local and fill in your values.

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Bearer token for authenticating with the backend API
NEXT_PUBLIC_BEARER_TOKEN=your-secret-bearer-token

# Admin panel password
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password
