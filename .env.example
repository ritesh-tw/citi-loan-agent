# =============================================================================
# Loan Application Agent - Backend Environment Configuration
# =============================================================================
# Copy this file to loan_application_agent/.env and fill in your values.

# LLM Gateway (Trustwise) - REQUIRED
# All LLM calls route through this gateway. Policies (PII, compliance) enforced automatically.
LLM_GATEWAY_BASE_URL=https://your-gateway-url.example.com
LLM_GATEWAY_API_KEY=your-gateway-api-key
LLM_MODEL=gpt-4o-mini

# Database (PostgreSQL) - REQUIRED for customer lookup & prequalification
DATABASE_URL=postgresql://username:password@localhost:5432/loan_agent

# Auth for external API callers (Trustwise evaluation / red-teaming)
API_BEARER_TOKEN=your-secret-bearer-token

# Additional API tokens for multiple external systems (OPTIONAL)
# Format: comma-separated "token:user_id" pairs
# CHAT_API_TOKENS=tk-redteam-abc123:redteam,tk-eval-xyz789:evaluator

# Google Drive (OPTIONAL - leave empty to disable Drive tools)
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Google Docs (OPTIONAL - leave empty to disable Docs tools)
GOOGLE_DOCS_SERVICE_ACCOUNT_JSON=

# Google Sheets (OPTIONAL - leave empty to disable Sheets tools)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

# GCP (for Vertex AI deployment & tracing)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Tracing (set to true to enable Cloud Trace export)
ENABLE_CLOUD_TRACE=false
